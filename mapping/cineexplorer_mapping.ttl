      JOIN role r ON tr.ROLE_ID = r.ROLE_ID
      WHERE r.ROLE_NAME = 'writer'
    """
  ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/person/{TALENT_ID}" ;
    rr:class ce:Writer
  ] .

<#Composer>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery """
      SELECT DISTINCT tr.TALENT_ID
      FROM talent_role tr
      JOIN role r ON tr.ROLE_ID = r.ROLE_ID
      WHERE r.ROLE_NAME IN ('composer', 'soundtrack')
    """
  ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/person/{TALENT_ID}" ;
    rr:class ce:Composer
  ] .

<#Editor>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery """
      SELECT DISTINCT tr.TALENT_ID
      FROM talent_role tr
      JOIN role r ON tr.ROLE_ID = r.ROLE_ID
      WHERE r.ROLE_NAME = 'editor'
    """
  ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/person/{TALENT_ID}" ;
    rr:class ce:Editor
  ] .

##################################################################
# 13. PERSON PROPERTIES (aggregated professions)
##################################################################

<#PersonProperties>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery """
      SELECT tr.TALENT_ID,
             GROUP_CONCAT(DISTINCT r.ROLE_NAME ORDER BY r.ROLE_NAME SEPARATOR ', ') AS ROLE_LIST
      FROM talent_role tr
      JOIN role r ON tr.ROLE_ID = r.ROLE_ID
      GROUP BY tr.TALENT_ID
    """
  ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/person/{TALENT_ID}"
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:personProperties ;
    rr:objectMap [ rr:column "ROLE_LIST" ; rr:datatype xsd:string ]
  ] .

##################################################################
# 14. PARTICIPATION
##################################################################

<#Participation>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery """
      SELECT tp.TITLE_ID,
             tp.TALENT_ID,
             tp.ORD,
             c.CATEGORY_NAME,
             tp.JOB
      FROM title_principal tp
      JOIN category c ON tp.CATEGORY_ID = c.CATEGORY_ID
    """
  ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/participation/{TITLE_ID}/{TALENT_ID}/{ORD}" ;
    rr:class ce:Participation
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:playedBy ;
    rr:objectMap [
      rr:template "https://example.org/cineexplorer/person/{TALENT_ID}" ;
      rr:termType rr:IRI
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:participatesIn ;
    rr:objectMap [
      rr:template "https://example.org/cineexplorer/title/{TITLE_ID}" ;
      rr:termType rr:IRI
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:participationRole ;
    rr:objectMap [ rr:column "CATEGORY_NAME" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:participationProperties ;
    rr:objectMap [ rr:column "JOB" ; rr:datatype xsd:string ]
  ] .

##################################################################
# 15. PERSON -> HAS ROLE (inverse-friendly materialization)
##################################################################

<#PersonHasRole>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "title_principal" ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/person/{TALENT_ID}"
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:hasRole ;
    rr:objectMap [
      rr:template "https://example.org/cineexplorer/participation/{TITLE_ID}/{TALENT_ID}/{ORD}" ;
      rr:termType rr:IRI
    ]
  ] .

##################################################################
# 16. CHARACTER NAMES -> added to the same Participation IRI
##################################################################

<#CharacterName>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "principal_role" ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/participation/{TITLE_ID}/{TALENT_ID}/{ORD}"
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:characterName ;
    rr:objectMap [ rr:column "ROLE_NAME" ; rr:datatype xsd:string ]
  ] .

