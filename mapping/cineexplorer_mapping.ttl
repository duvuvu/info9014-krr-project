##################################################################
# CineExplorer R2RML Mapping (finalized for revised ontology v5)
#
# Source system : MySQL imdb database
# Target        : https://example.org/cineexplorer/ontology#
# Strategy      : stable IMDb-based IRIs + contextual Participation
#
# Run with a SQL-capable R2RML engine, for example:
#   java -jar r2rml.jar mapping.properties
#
# mapping.properties example:
#   connectionURL = jdbc:mysql://localhost:3307/imdb
#   user          = imdb_user
#   password      = imdb_pass
#   mappingFile   = cineexplorer_mapping_final.ttl
#   outputFile    = output/cineexplorer_kg.ttl
#   format        = TURTLE
##################################################################

@prefix rr:   <http://www.w3.org/ns/r2rml#> .
@prefix ce:   <https://example.org/cineexplorer/ontology#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

##################################################################
# IRI strategy
#   Title          https://example.org/cineexplorer/title/{TITLE_ID}
#   Person         https://example.org/cineexplorer/person/{TALENT_ID}
#   Genre          https://example.org/cineexplorer/genre/{GENRE_ID}
#   Participation  https://example.org/cineexplorer/participation/{TITLE_ID}/{TALENT_ID}/{ORD}
#
# These IRIs are stable because they reuse the source IMDb identifiers.
##################################################################

##################################################################
# 1. FILM
##################################################################

<#Film>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery """
      SELECT t.TITLE_ID,
             t.PRIMARY_TITLE,
             t.ORIGINAL_TITLE,
             t.START_YEAR,
             t.END_YEAR,
             t.RUNTIME_MINUTES,
             t.IS_ADULT,
             ct.CONTENT_TYPE_NAME
      FROM title t
      JOIN content_type ct ON t.CONTENT_TYPE_ID = ct.CONTENT_TYPE_ID
      WHERE t.CONTENT_TYPE_ID IN (1, 2, 3, 6, 8, 9)
        AND NOT EXISTS (
          SELECT 1 FROM title_episode te
          WHERE te.TITLE_ID = t.TITLE_ID
        )
    """
  ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/title/{TITLE_ID}" ;
    rr:class ce:Film
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:workTitle ;
    rr:objectMap [ rr:column "PRIMARY_TITLE" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:releaseYear ;
    rr:objectMap [ rr:column "START_YEAR" ; rr:datatype xsd:gYear ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:runtimeMinutes ;
    rr:objectMap [ rr:column "RUNTIME_MINUTES" ; rr:datatype xsd:nonNegativeInteger ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:isAdult ;
    rr:objectMap [ rr:column "IS_ADULT" ; rr:datatype xsd:boolean ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:creativeWorkProperties ;
    rr:objectMap [ rr:template "originalTitle={ORIGINAL_TITLE}; endYear={END_YEAR}; contentType={CONTENT_TYPE_NAME}" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [ rr:column "PRIMARY_TITLE" ; rr:language "en" ]
  ] .

##################################################################
# 2. SERIES
##################################################################

<#Series>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery """
      SELECT t.TITLE_ID,
             t.PRIMARY_TITLE,
             t.ORIGINAL_TITLE,
             t.START_YEAR,
             t.END_YEAR,
             t.RUNTIME_MINUTES,
             t.IS_ADULT,
             ct.CONTENT_TYPE_NAME
      FROM title t
      JOIN content_type ct ON t.CONTENT_TYPE_ID = ct.CONTENT_TYPE_ID
      WHERE t.CONTENT_TYPE_ID IN (4, 7)
        AND NOT EXISTS (
          SELECT 1 FROM title_episode te
          WHERE te.TITLE_ID = t.TITLE_ID
        )
    """
  ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/title/{TITLE_ID}" ;
    rr:class ce:Series
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:workTitle ;
    rr:objectMap [ rr:column "PRIMARY_TITLE" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:releaseYear ;
    rr:objectMap [ rr:column "START_YEAR" ; rr:datatype xsd:gYear ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:runtimeMinutes ;
    rr:objectMap [ rr:column "RUNTIME_MINUTES" ; rr:datatype xsd:nonNegativeInteger ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:isAdult ;
    rr:objectMap [ rr:column "IS_ADULT" ; rr:datatype xsd:boolean ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:creativeWorkProperties ;
    rr:objectMap [ rr:template "originalTitle={ORIGINAL_TITLE}; endYear={END_YEAR}; contentType={CONTENT_TYPE_NAME}" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [ rr:column "PRIMARY_TITLE" ; rr:language "en" ]
  ] .

##################################################################
# 3. EPISODE
##################################################################

<#Episode>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery """
      SELECT t.TITLE_ID,
             t.PRIMARY_TITLE,
             t.ORIGINAL_TITLE,
             t.START_YEAR,
             t.END_YEAR,
             t.RUNTIME_MINUTES,
             t.IS_ADULT,
             te.PARENT_TITLE_ID,
             te.SEASON_NUMBER,
             te.EPISODE_NUMBER
      FROM title t
      JOIN title_episode te ON t.TITLE_ID = te.TITLE_ID
      WHERE te.PARENT_TITLE_ID IS NOT NULL
    """
  ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/title/{TITLE_ID}" ;
    rr:class ce:Episode
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:workTitle ;
    rr:objectMap [ rr:column "PRIMARY_TITLE" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:releaseYear ;
    rr:objectMap [ rr:column "START_YEAR" ; rr:datatype xsd:gYear ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:runtimeMinutes ;
    rr:objectMap [ rr:column "RUNTIME_MINUTES" ; rr:datatype xsd:nonNegativeInteger ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:isAdult ;
    rr:objectMap [ rr:column "IS_ADULT" ; rr:datatype xsd:boolean ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:seasonNumber ;
    rr:objectMap [ rr:column "SEASON_NUMBER" ; rr:datatype xsd:nonNegativeInteger ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:episodeNumber ;
    rr:objectMap [ rr:column "EPISODE_NUMBER" ; rr:datatype xsd:nonNegativeInteger ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:episodeProperties ;
    rr:objectMap [ rr:template "originalTitle={ORIGINAL_TITLE}; endYear={END_YEAR}" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:partOfSeries ;
    rr:objectMap [
      rr:template "https://example.org/cineexplorer/title/{PARENT_TITLE_ID}" ;
      rr:termType rr:IRI
    ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [ rr:column "PRIMARY_TITLE" ; rr:language "en" ]
  ] .

##################################################################
# 4. SERIES -> HAS EPISODE (inverse traversal-friendly materialization)
##################################################################

<#SeriesHasEpisode>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "title_episode" ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/title/{PARENT_TITLE_ID}"
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:hasEpisode ;
    rr:objectMap [
      rr:template "https://example.org/cineexplorer/title/{TITLE_ID}" ;
      rr:termType rr:IRI
    ]
  ] .

##################################################################
# 5. GENRE
##################################################################

<#Genre>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "genre" ] ;
  rr:subjectMap [
