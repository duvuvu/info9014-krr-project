    rr:class ce:Genre
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:genreName ;
    rr:objectMap [ rr:column "GENRE_NAME" ; rr:datatype xsd:string ]
  ] ;
  rr:predicateObjectMap [
    rr:predicate rdfs:label ;
    rr:objectMap [ rr:column "GENRE_NAME" ; rr:language "en" ]
  ] .

