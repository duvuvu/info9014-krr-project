# 6. TITLE -> GENRE / GENRE -> TITLE
##################################################################

<#TitleHasGenre>
  a rr:TriplesMap ;
  rr:logicalTable [ rr:tableName "title_genre" ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/title/{TITLE_ID}"
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:hasGenre ;
    rr:objectMap [
      rr:template "https://example.org/cineexplorer/genre/{GENRE_ID}" ;
      rr:termType rr:IRI
    ]
  ] .

<#GenreOfTitle>
  a rr:TriplesMap ;
