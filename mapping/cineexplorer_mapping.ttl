    """
  ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/person/{TALENT_ID}"
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:composedFor ;
    rr:objectMap [
      rr:template "https://example.org/cineexplorer/title/{TITLE_ID}" ;
      rr:termType rr:IRI
    ]
  ] .

<#ComposedBy>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery """
      SELECT DISTINCT tp.TITLE_ID, tp.TALENT_ID
      FROM title_principal tp
      JOIN category c ON tp.CATEGORY_ID = c.CATEGORY_ID
      WHERE c.CATEGORY_NAME = 'composer'
    """
  ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/title/{TITLE_ID}"
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:composedBy ;
    rr:objectMap [
      rr:template "https://example.org/cineexplorer/person/{TALENT_ID}" ;
      rr:termType rr:IRI
    ]
  ] .

##################################################################
# 20. PERSON <-> PERSON COLLABORATION LINKS
##################################################################

<#WorkedWith>
  a rr:TriplesMap ;
  rr:logicalTable [
    rr:sqlQuery """
      SELECT DISTINCT tp1.TALENT_ID AS TALENT_ID_1,
                      tp2.TALENT_ID AS TALENT_ID_2
      FROM title_principal tp1
      JOIN title_principal tp2
        ON tp1.TITLE_ID = tp2.TITLE_ID
       AND tp1.TALENT_ID <> tp2.TALENT_ID
    """
  ] ;
  rr:subjectMap [
    rr:template "https://example.org/cineexplorer/person/{TALENT_ID_1}"
  ] ;
  rr:predicateObjectMap [
    rr:predicate ce:workedWith ;
    rr:objectMap [
      rr:template "https://example.org/cineexplorer/person/{TALENT_ID_2}" ;
      rr:termType rr:IRI
    ]
  ] .
