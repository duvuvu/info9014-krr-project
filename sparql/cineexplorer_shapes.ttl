@prefix sh:  <http://www.w3.org/ns/shacl#> .
@prefix ce:  <http://cineexplorer.local/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

# Shape 1: Every CreativeWork must have exactly one workTitle (xsd:string),
#          exactly one averageRating in [1.0, 10.0] and exactly one numVotes >= 0.
#          Ratings are mandatory because the source slice is selected by numVotes DESC top-N
#          per title type — every title carried into the KG was chosen on that criterion.
ce:CreativeWorkShape a sh:NodeShape ;
  sh:targetClass ce:CreativeWork ;
  sh:property [
    sh:path     ce:workTitle ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message  "Every CreativeWork must have exactly one workTitle of type xsd:string."
  ] ;
  sh:property [
    sh:path         ce:averageRating ;
    sh:minCount     1 ;
    sh:maxCount     1 ;
    sh:datatype     xsd:decimal ;
    sh:minInclusive 1.0 ;
    sh:maxInclusive 10.0 ;
    sh:message      "Every CreativeWork must have exactly one averageRating (xsd:decimal) in the IMDb range [1.0, 10.0]."
  ] ;
  sh:property [
    sh:path         ce:numVotes ;
    sh:minCount     1 ;
    sh:maxCount     1 ;
    sh:datatype     xsd:nonNegativeInteger ;
    sh:minInclusive 0 ;
    sh:message      "Every CreativeWork must have exactly one numVotes (xsd:nonNegativeInteger >= 0)."
  ] .

# Shape 2: Every Person must have exactly one personName (xsd:string).
#          hasProfession is optional (some IMDb persons have no primaryProfession);
#          when present, each value must be an xsd:string. Up to ~3 are expected
#          (IMDb's primaryProfession field stores 1-3 comma-separated values).
ce:PersonShape a sh:NodeShape ;
  sh:targetClass ce:Person ;
  sh:property [
    sh:path     ce:personName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message  "Every Person must have exactly one personName of type xsd:string."
  ] ;
  sh:property [
    sh:path     ce:hasProfession ;
    sh:datatype xsd:string ;
    sh:maxCount 3 ;
    sh:message  "Each hasProfession value must be an xsd:string; IMDb's primaryProfession holds at most 3."
  ] .

# Shape 3: Every Episode must link to exactly one Series via ce:partOfSeries
ce:EpisodeShape a sh:NodeShape ;
  sh:targetClass ce:Episode ;
  sh:property [
    sh:path     ce:partOfSeries ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class    ce:Series ;
    sh:message  "Every Episode must be linked to exactly one Series via ce:partOfSeries."
  ] .

# Shape 4: Every Participation must link to exactly one Person, one CreativeWork,
#           and have at least one participationRole string
ce:ParticipationShape a sh:NodeShape ;
  sh:targetClass ce:Participation ;
  sh:property [
    sh:path     ce:playedBy ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class    ce:Person ;
    sh:message  "Every Participation must link to exactly one Person via ce:playedBy."
  ] ;
  sh:property [
    sh:path     ce:participatesIn ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:class    ce:CreativeWork ;
    sh:message  "Every Participation must link to exactly one CreativeWork via ce:participatesIn."
  ] ;
  sh:property [
    sh:path     ce:participationRole ;
    sh:minCount 1 ;
    sh:datatype xsd:string ;
    sh:message  "Every Participation must have at least one participationRole string."
  ] .

# Shape 5: Every Genre must have exactly one genreName (xsd:string).
ce:GenreShape a sh:NodeShape ;
  sh:targetClass ce:Genre ;
  sh:property [
    sh:path     ce:genreName ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string ;
    sh:message  "Every Genre must have exactly one genreName of type xsd:string."
  ] .
