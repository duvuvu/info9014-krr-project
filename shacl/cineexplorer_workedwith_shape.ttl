@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ce: <http://cineexplorer.local/ontology#> .

ce:WorkedWithShape
    a sh:NodeShape ;
    sh:targetClass ce:Person ;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "The person {$this} worked on the same project as {?person2}, but the ce:workedWith relationship is missing." ;
        sh:select """
            PREFIX ce: <http://cineexplorer.local/ontology#>
            SELECT DISTINCT $this ?person2
            WHERE {
                $this ce:workedFor ?work .
                ?person2 ce:workedFor ?work .
                FILTER ($this != ?person2)

                FILTER NOT EXISTS { $this ce:workedWith ?person2 }
            }
        """
    ] .
