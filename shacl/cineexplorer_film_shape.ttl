@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix ce: <http://cineexplorer.local/ontology#> .

ce:FilmShape
    a sh:NodeShape ;
    sh:targetClass ce:Film ;
    sh:property [
        sh:path ce:workTitle ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:name "Work Title" ;
    ] ;
    sh:property [
        sh:path ce:releaseYear ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:gYear ;
        sh:name "Release Year" ;
    ] .
